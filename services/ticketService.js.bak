const db = require('../db/connection');
const SLAService = require('./slaService');

class TicketService {
  /**
   * Criar novo ticket
   */
  static criarTicket(setor, nome, descricao) {
    return new Promise((resolve, reject) => {
      const sql = `
        INSERT INTO tickets (setor, nome, descricao, status, criado_em)
        VALUES (?, ?, ?, 'aberto', datetime('now', 'localtime'))
      `;

      db.run(sql, [setor, nome || null, descricao], function(err) {
        if (err) {
          console.error('Erro ao criar ticket:', err);
          return reject(new Error('Erro ao criar ticket no banco de dados'));
        }

        resolve({
          id: this.lastID,
          message: 'Ticket criado com sucesso'
        });
      });
    });
  }

  /**
   * Iniciar atendimento - Operação ATÔMICA
   */
  static iniciarTicket(id, prioridade, analista) {
    return new Promise((resolve, reject) => {
      const prioridadesValidas = ['Baixa', 'Média', 'Alta', 'Crítica'];
      if (!prioridadesValidas.includes(prioridade)) {
        return reject(new Error('Prioridade inválida. Use: Baixa, Média, Alta ou Crítica'));
      }

      const slaTotal = SLAService.calcularSLATotal(prioridade);
      const agora = new Date().toISOString();

      db.serialize(() => {
        db.run('BEGIN TRANSACTION');

        db.get(
          'SELECT id, status FROM tickets WHERE id = ? AND deletado = 0',
          [id],
          (err, ticket) => {
            if (err) {
              db.run('ROLLBACK');
              return reject(err);
            }

            if (!ticket) {
              db.run('ROLLBACK');
              return reject(new Error('Ticket não encontrado ou está na lixeira'));
            }

            if (ticket.status !== 'aberto' && ticket.status !== 'reaberto') {
              db.run('ROLLBACK');
              return reject(new Error(`Ticket #${id} não pode ser iniciado. Status atual: ${ticket.status}`));
            }

            if (ticket.status === 'reaberto') {
              db.run(
                'UPDATE tickets SET reabertura_aceita = 1 WHERE id = ?',
                [id],
                (err) => {
                  if (err) {
                    db.run('ROLLBACK');
                    return reject(err);
                  }
                }
              );
            }

            const sql = `
              UPDATE tickets
              SET status = 'em andamento',
                  prioridade = ?,
                  iniciado_em = ?,
                  sla_total_min = ?,
                  sla_consumido_min = 0,
                  sla_estourado = 0,
                  analista_responsavel = ?,
                  ultima_atualizacao = ?
              WHERE id = ? AND deletado = 0
            `;

            db.run(sql, [prioridade, agora, slaTotal, analista, agora, id], function(err) {
              if (err) {
                db.run('ROLLBACK');
                return reject(err);
              }

              if (this.changes === 0) {
                db.run('ROLLBACK');
                return reject(new Error('Falha ao iniciar ticket. Tente novamente.'));
              }

              db.run('COMMIT');

              resolve({
                message: `Ticket #${id} iniciado com prioridade ${prioridade}`,
                sla_total_min: slaTotal,
                prioridade: prioridade
              });
            });
          }
        );
      });
    });
  }

  /**
   * Concluir ticket
   */
  static concluirTicket(id, descricaoFinal, justificativaSLA, linkRef) {
    return new Promise((resolve, reject) => {
      const agora = new Date();
      const agoraISO = agora.toISOString();

      db.get(
        'SELECT * FROM tickets WHERE id = ? AND deletado = 0 AND status = ?',
        [id, 'em andamento'],
        (err, ticket) => {
          if (err) return reject(err);

          if (!ticket) {
            return reject(new Error('Ticket não encontrado ou não está em andamento'));
          }

          const slaConsumido = SLAService.calcularMinutosUteis(
            new Date(ticket.iniciado_em),
            agora
          );

          const slaEstourado = slaConsumido > ticket.sla_total_min ? 1 : 0;

          if (slaEstourado && (!justificativaSLA || !justificativaSLA.trim())) {
            return reject(new Error('SLA estourado. Justificativa obrigatória.'));
          }

          const sql = `
            UPDATE tickets
            SET status = 'concluído',
                concluido_em = ?,
                sla_consumido_min = ?,
                sla_estourado = ?,
                sla_justificativa = ?,
                descricao_final = ?,
                link_referencia = ?,
                ultima_atualizacao = ?
            WHERE id = ? AND status = 'em andamento' AND deletado = 0
          `;

          db.run(
            sql,
            [agoraISO, slaConsumido, slaEstourado, justificativaSLA || null, descricaoFinal, linkRef || null, agoraISO, id],
            function(err) {
              if (err) return reject(err);

              if (this.changes === 0) {
                return reject(new Error('Falha ao concluir ticket. Tente novamente.'));
              }

              resolve({
                message: 'Ticket concluído com sucesso',
                sla_consumido_min: slaConsumido,
                sla_estourado: slaEstourado
              });
            }
          );
        }
      );
    });
  }

  /**
   * Reabrir ticket
   */
  static reabrirTicket(id, motivo) {
    return new Promise((resolve, reject) => {
      db.get(
        'SELECT * FROM tickets WHERE id = ? AND deletado = 0 AND status = ?',
        [id, 'concluído'],
        (err, ticket) => {
          if (err) return reject(err);

          if (!ticket) {
            return reject(new Error('Ticket não encontrado ou não está concluído'));
          }

          const originalId = ticket.ticket_original_id || ticket.id;

          // Verificar se o ticket original tem bloqueio de recusa
          db.get(
            `SELECT justificativa_recusa_reabertura FROM tickets WHERE id = ?`,
            [originalId],
            (err, row) => {
              if (err) return reject(err);

              if (row && row.justificativa_recusa_reabertura) {
                return reject(new Error('Não é possível reabrir. Uma reabertura anterior foi recusada pelo analista.'));
              }

              // Verificar reaberturas recusadas nos filhos
              db.get(
                `SELECT COUNT(*) as count FROM tickets WHERE ticket_original_id = ? AND reabertura_aceita = 0 AND deletado = 0`,
                [originalId],
                (err, rowFilhos) => {
                  if (err) return reject(err);

                  if (rowFilhos.count > 0) {
                    return reject(new Error('Não é possível reabrir. Uma reabertura anterior foi recusada pelo analista.'));
                  }

                  // Verificar limite de ciclos
                  db.get(
                    'SELECT COUNT(*) as count FROM tickets WHERE (id = ? OR ticket_original_id = ?) AND deletado = 0',
                    [originalId, originalId],
                    (err, rowCiclos) => {
                      if (err) return reject(err);

                      const totalCiclos = rowCiclos.count;
                      if (totalCiclos >= 3) {
                        return reject(new Error('Limite máximo de reaberturas atingido (2 reaberturas por ticket).'));
                      }

                      const sql = `
                        INSERT INTO tickets (
                          setor, nome, descricao, status,
                          ciclo, ticket_original_id, motivo_reabertura,
                          criado_em, ultima_atualizacao
                        ) VALUES (?, ?, ?, 'reaberto', ?, ?, ?, datetime('now', 'localtime'), datetime('now', 'localtime'))
                      `;

                      const novoCiclo = (ticket.ciclo || 1) + 1;

                      db.run(
                        sql,
                        [ticket.setor, ticket.nome, ticket.descricao, novoCiclo, originalId, motivo],
                        function(err) {
                          if (err) return reject(err);

                          resolve({
                            id: this.lastID,
                            message: 'Ticket reaberto com sucesso. Aguardando aceitação do analista.',
                            ticket_original: originalId,
                            ciclo: novoCiclo
                          });
                        }
                      );
                    }
                  );
                }
              );
            }
          );
        }
      );
    });
  }

  /**
   * Aceitar reabertura
   */
  static aceitarReabertura(id, prioridade, analista) {
    return new Promise((resolve, reject) => {
      const prioridadesValidas = ['Baixa', 'Média', 'Alta', 'Crítica'];
      if (!prioridadesValidas.includes(prioridade)) {
        return reject(new Error('Prioridade inválida'));
      }

      db.run(
        `UPDATE tickets SET reabertura_aceita = 1 WHERE id = ? AND status = 'reaberto' AND deletado = 0`,
        [id],
        function(err) {
          if (err) return reject(err);
          if (this.changes === 0) {
            return reject(new Error('Ticket não encontrado ou não está reaberto'));
          }

          resolve(TicketService.iniciarTicket(id, prioridade, analista));
        }
      );
    });
  }

  /**
   * Recusar reabertura - Bloqueia ticket original
   */
  static recusarReabertura(id, justificativa) {
    return new Promise((resolve, reject) => {
      const agora = new Date().toISOString();

      const sql = `
        UPDATE tickets
        SET status = 'concluído',
            reabertura_aceita = 0,
            justificativa_recusa_reabertura = ?,
            concluido_em = ?,
            ultima_atualizacao = ?
        WHERE id = ? AND status = 'reaberto' AND deletado = 0
      `;

      db.run(sql, [justificativa, agora, agora, id], function(err) {
        if (err) return reject(err);

        if (this.changes === 0) {
          return reject(new Error('Ticket não encontrado ou não está reaberto'));
        }

        // Bloquear ticket original
        db.get(
          'SELECT ticket_original_id FROM tickets WHERE id = ?',
          [id],
          (err, row) => {
            if (err) return reject(err);

            if (row && row.ticket_original_id) {
              db.run(
                `UPDATE tickets 
                 SET justificativa_recusa_reabertura = ?,
                     ultima_atualizacao = ?
                 WHERE id = ?`,
                [`Reabertura #${id} recusada em ${agora}: ${justificativa}`, agora, row.ticket_original_id],
                (err) => {
                  if (err) console.error('Erro ao atualizar ticket original:', err);
                }
              );
            }

            resolve({ 
              message: 'Reabertura recusada com sucesso. Ticket original bloqueado para novas reaberturas.' 
            });
          }
        );
      });
    });
  }

  /**
   * Excluir ticket (soft delete)
   */
  static excluirTicket(id, perfil, usuario, motivo) {
    return new Promise((resolve, reject) => {
      let condicaoStatus;

      if (perfil === 'solicitante') {
        condicaoStatus = "status = 'aberto'";
      } else if (perfil === 'analista') {
        condicaoStatus = "status = 'concluído'";
      } else {
        return reject(new Error('Perfil não autorizado para excluir tickets'));
      }

      const agora = new Date().toISOString();

      const sql = `
        UPDATE tickets
        SET deletado = 1,
            deletado_por = ?,
            motivo_exclusao = ?,
            deletado_em = ?,
            ultima_atualizacao = ?
        WHERE id = ? AND ${condicaoStatus} AND deletado = 0
      `;

      db.run(sql, [`${perfil}: ${usuario}`, motivo, agora, agora, id], function(err) {
        if (err) return reject(err);

        if (this.changes === 0) {
          return reject(new Error(
            `Exclusão não permitida. ${perfil === 'solicitante' ? 'Apenas tickets ABERTOS podem ser excluídos.' : 'Apenas tickets CONCLUÍDOS podem ser excluídos.'}`
          ));
        }

        resolve({ message: 'Ticket enviado para lixeira com sucesso' });
      });
    });
  }

  /**
   * Editar ticket (apenas ABERTO e se for solicitante)
   */
  static editarTicket(id, dados) {
    return new Promise((resolve, reject) => {
      db.get(
        "SELECT * FROM tickets WHERE id = ? AND status = 'aberto' AND deletado = 0",
        [id],
        (err, ticket) => {
          if (err) return reject(err);

          if (!ticket) {
            return reject(new Error('Edição permitida apenas para tickets ABERTOS'));
          }

          const agora = new Date().toISOString();
          const setor = dados.setor || ticket.setor;
          const nome = dados.nome !== undefined ? dados.nome : ticket.nome;
          const descricao = dados.descricao || ticket.descricao;

          const sql = `
            UPDATE tickets
            SET setor = ?, nome = ?, descricao = ?, ultima_atualizacao = ?
            WHERE id = ?
          `;

          db.run(sql, [setor, nome, descricao, agora, id], function(err) {
            if (err) return reject(err);
            resolve({ message: 'Ticket atualizado com sucesso' });
          });
        }
      );
    });
  }

  /**
   * Listar tickets com cálculo de SLA em tempo real
   */
  static listarTickets(filtros = {}) {
    return new Promise((resolve, reject) => {
      let sql = `
        SELECT
          id, setor, nome, descricao, status, prioridade,
          criado_em, iniciado_em, concluido_em,
          sla_total_min, sla_consumido_min, sla_estourado,
          sla_justificativa, analista_responsavel, descricao_final,
          link_referencia,
          ciclo, ticket_original_id, motivo_reabertura,
          reabertura_aceita, justificativa_recusa_reabertura
        FROM tickets
        WHERE deletado = 0
      `;

      const params = [];

      if (filtros.status) {
        sql += ' AND status = ?';
        params.push(filtros.status);
      }

      if (filtros.setor) {
        sql += ' AND setor = ?';
        params.push(filtros.setor);
      }

      if (filtros.prioridade) {
        sql += ' AND prioridade = ?';
        params.push(filtros.prioridade);
      }

      sql += `
        ORDER BY
          CASE prioridade
            WHEN 'Crítica' THEN 1
            WHEN 'Alta' THEN 2
            WHEN 'Média' THEN 3
            WHEN 'Baixa' THEN 4
            ELSE 5
          END,
          criado_em ASC
      `;

      db.all(sql, params, (err, tickets) => {
        if (err) return reject(err);

        const agora = new Date();
        const ticketsComSLA = tickets.map(ticket => {
          const ticketObj = { ...ticket };

          if (ticket.status === 'em andamento' && ticket.iniciado_em) {
            const slaConsumido = SLAService.calcularMinutosUteis(
              new Date(ticket.iniciado_em),
              agora
            );

            const slaStatus = SLAService.calcularStatusSLA(
              ticket.sla_total_min,
              slaConsumido
            );

            ticketObj.sla_consumido_atual = slaConsumido;
            ticketObj.sla_status = slaStatus;
          } else if (ticket.sla_estourado) {
            ticketObj.sla_status = 'estourado';
          } else {
            ticketObj.sla_status = 'ok';
          }

          return ticketObj;
        });

        resolve(ticketsComSLA);
      });
    });
  }

  /**
   * Buscar ticket por ID
   */
  static buscarTicketPorId(id) {
    return new Promise((resolve, reject) => {
      db.get('SELECT * FROM tickets WHERE id = ?', [id], (err, ticket) => {
        if (err) return reject(err);
        if (!ticket) {
          return reject(new Error('Ticket não encontrado'));
        }

        if (ticket.status === 'em andamento' && ticket.iniciado_em) {
          const agora = new Date();
          ticket.sla_consumido_atual = SLAService.calcularMinutosUteis(
            new Date(ticket.iniciado_em),
            agora
          );
          ticket.sla_status = SLAService.calcularStatusSLA(
            ticket.sla_total_min,
            ticket.sla_consumido_atual
          );
        }

        resolve(ticket);
      });
    });
  }

  /**
   * Listar lixeira
   */
  static listarLixeira() {
    return new Promise((resolve, reject) => {
      const sql = `
        SELECT * FROM tickets
        WHERE deletado = 1
        ORDER BY deletado_em DESC
      `;

      db.all(sql, [], (err, tickets) => {
        if (err) return reject(err);
        resolve(tickets);
      });
    });
  }

  /**
   * Obter estatísticas para gestão
   */
  static obterEstatisticas() {
    return new Promise((resolve, reject) => {
      const stats = {};
      let queriesCompletas = 0;
      const TOTAL_QUERIES = 3;

      const checkComplete = () => {
        queriesCompletas++;
        if (queriesCompletas >= TOTAL_QUERIES) {
          resolve(stats);
        }
      };

      db.get(
        "SELECT COUNT(*) as total FROM tickets WHERE deletado = 0",
        (err, row) => {
          if (err) return reject(err);
          stats.total = row.total;
        }
      );

      db.all(
        "SELECT status, COUNT(*) as count FROM tickets WHERE deletado = 0 GROUP BY status",
        (err, rows) => {
          if (err) return reject(err);
          stats.por_status = rows;
          checkComplete();
        }
      );

      db.get(
        "SELECT COUNT(*) as count FROM tickets WHERE sla_estourado = 1 AND deletado = 0",
        (err, row) => {
          if (err) return reject(err);
          stats.sla_estourados = row.count;
        }
      );

      db.all(
        `SELECT
          prioridade,
          ROUND(AVG(sla_consumido_min)) as tempo_medio,
          COUNT(*) as total
        FROM tickets
        WHERE status = 'concluído' AND deletado = 0 AND sla_consumido_min IS NOT NULL AND prioridade IS NOT NULL
        GROUP BY prioridade`,
        (err, rows) => {
          if (err) return reject(err);
          stats.tempo_medio_prioridade = rows || [];
          checkComplete();
        }
      );

      db.all(
        "SELECT setor, COUNT(*) as count FROM tickets WHERE deletado = 0 GROUP BY setor",
        (err, rows) => {
          if (err) return reject(err);
          stats.por_setor = rows || [];
          checkComplete();
        }
      );
    });
  }

  /**
   * Verificar se existe reabertura recusada para o ticket original
   */
  static verificarReaberturasRecusadas(ticketOriginalId) {
    return new Promise((resolve, reject) => {
      db.get(
        `SELECT COUNT(*) as count FROM tickets WHERE ticket_original_id = ? AND reabertura_aceita = 0 AND deletado = 0`,
        [ticketOriginalId],
        (err, rowFilhos) => {
          if (err) return reject(err);

          if (rowFilhos.count > 0) {
            return resolve(true);
          }

          db.get(
            `SELECT justificativa_recusa_reabertura FROM tickets WHERE id = ?`,
            [ticketOriginalId],
            (err, rowOriginal) => {
              if (err) return reject(err);
              const bloqueado = rowOriginal && rowOriginal.justificativa_recusa_reabertura ? true : false;
              resolve(bloqueado);
            }
          );
        }
      );
    });
  }

  /**
   * Contar total de ciclos de um ticket
   */
  static contarCiclos(ticketId) {
    return new Promise((resolve, reject) => {
      db.get('SELECT * FROM tickets WHERE id = ?', [ticketId], (err, ticket) => {
        if (err) return reject(err);
        if (!ticket) return resolve(0);

        const idOriginal = ticket.ticket_original_id || ticket.id;

        db.get(
          'SELECT COUNT(*) as count FROM tickets WHERE (id = ? OR ticket_original_id = ?) AND deletado = 0',
          [idOriginal, idOriginal],
          (err, row) => {
            if (err) return reject(err);
            resolve(row.count);
          }
        );
      });
    });
  }
}

module.exports = TicketService;
